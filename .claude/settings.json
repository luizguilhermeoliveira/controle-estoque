{
  "permissions": {
    "allow": [
      "Bash(docker compose exec app php artisan:*)",
      "Bash(docker compose exec app composer:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose build:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(docker compose down -v:*)",
      "Read(./.env)"
    ]
  }
}
